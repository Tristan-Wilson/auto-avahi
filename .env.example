# Auto-Avahi Configuration Example
# Copy to .env and customize

# Comma-separated list of allowed hostname suffixes (no leading dot).
# Only Traefik Host() values ending with one of these are processed.
# Default: local
HOSTNAME_SUFFIXES=local

# Whether to publish hostnames via mDNS (avahi-publish).
# Set to "false" if DNS is handled elsewhere (split-horizon, public DNS,
# /etc/hosts, etc.). When false, AVAHI_HOST_IP is not required.
# Default: true
MDNS_ENABLE=true

# Required when MDNS_ENABLE=true: IP address advertised in mDNS records.
# Leave empty when MDNS_ENABLE=false.
AVAHI_HOST_IP=192.168.1.100

# Optional: Directory for generated certificates (on host)
# Default: /certs
CERT_DIR=./certs

# Optional: Path where certificates are mounted inside Traefik container
# Default: /certs
# This is what appears in the Traefik YAML config files
CERT_DIR_CONTAINER=/certs

# Optional: Directory for Traefik cert YAML files
# Default: /traefik/dynamic
TRAEFIK_CONFIG_DIR=./traefik/dynamic

# Optional: mkcert CA root directory
# Set this if the service runs as root but you want certificates signed by
# a different user's mkcert CA (the one browsers on your LAN trust).
# Find the path by running as that user: mkcert -CAROOT
# Default: (empty, uses mkcert's default for the running user)
#CAROOT=/home/youruser/.local/share/mkcert
